# Copie para frontend/.env e preencha (não commitar .env).
# Valores oficiais: Supabase → Project Settings → API (Project URL + anon public).
# Builds de loja (EAS): use as mesmas variáveis no projeto EAS (ambiente production).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Easypanel (legado Site): VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_API_URL também funcionam no Docker

# API do Site/backend — produção (Easypanel)
# EXPO_PUBLIC_MEI_API_URL=https://auto-back-meufinanceiro-site.4tnf3f.easypanel.host

# URL pública deste app (FOCO MEI) — links legais, convites, OAuth
# EXPO_PUBLIC_INVITE_APP_BASE_URL=https://focomei.com.br

# Só em dev (Expo __DEV__): sobrescreve a URL acima no localhost (web) ou no Expo Go
# Web no PC: http://localhost:3333
# Celular físico (Expo Go): use o IP da máquina na mesma rede Wi‑Fi, ex.:
# EXPO_PUBLIC_MEI_API_URL_DEV=http://192.168.0.12:3333
# (O app tenta detectar o IP do Metro automaticamente; se falhar, usa a URL de produção.)
