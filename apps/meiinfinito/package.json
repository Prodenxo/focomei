{
  "name": "financas-pessoais-app",
  "private": true,
  "version": "1.0.0",
  "description": "Aplicação de finanças pessoais - Frontend e Backend",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd frontend && npm run build && cd .. && node scripts/copy-dist-to-root.js",
    "preview": "cd frontend && npm run preview",
    "lint": "npm run lint --workspaces --if-present",
    "lint:backend": "npm run lint -w backend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "sync:ide": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync",
    "sync:ide:validate": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate",
    "sync:ide:check": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate --strict",
    "sync:ide:cursor": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync --ide cursor",
    "sync:ide:codex": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync --ide codex",
    "sync:ide:claude": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync --ide claude-code",
    "sync:skills:codex": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js",
    "sync:skills:codex:global": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js --global",
    "validate:structure": "node .aiox-core/infrastructure/scripts/validate-paths.js",
    "validate:agents": "node .aiox-core/infrastructure/scripts/validate-agents.js",
    "db:migrate:prod:check": "node scripts/supabase-migrate-prod.mjs --check",
    "db:migrate:prod": "node scripts/supabase-migrate-prod.mjs --apply",
    "db:migrate:recorrencias": "cd backend && node ../scripts/apply-recorrencias-migrations.mjs",
    "db:apply:empresa-invites": "node scripts/apply-empresa-invites-via-pg.mjs",
    "db:verify:nfse-emitente-schema": "node scripts/nfse-emitente-user-mei-certificates-schema.mjs --check",
    "db:apply:nfse-emitente-schema": "node scripts/nfse-emitente-user-mei-certificates-schema.mjs --apply",
    "qa:corr03-smoke-backend": "cd backend && node --test tests/mei-guide-routes-emitente.test.js",
    "smoke:plugnotas:nfe-nfce": "node scripts/smoke-nfe-nfce-plugnotas.mjs"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "supabase": "^2.95.5"
  }
}
